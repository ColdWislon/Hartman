# Copy to .env and fill in. Credentials live here, never in config.yaml.

# Long-lived Tuleap personal access key (sent as X-Auth-AccessKey).
# Do NOT use the 24h /api/tokens token.
TULEAP_ACCESS_KEY=

# Optional HTTPS PAT scoped to git read (or mount an SSH key instead).
GIT_HTTP_PAT=

# Base URL used by the API to build outbound Tuleap hyperlinks.
TULEAP_BASE_URL=https://tuleap.example.com

# --- build stage ---
FROM node:20-slim AS build
WORKDIR /app
COPY web/package.json ./package.json
RUN npm install
COPY web/ ./
RUN npm run build

# --- serve stage ---
FROM nginx:1.27-alpine
COPY web/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist /usr/share/nginx/html
EXPOSE 80
